// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum DocumentStatus {
  DRAFT
  REVIEW
  APPROVED
  ARCHIVED
}

enum PppDocumentType {
  KS
  WWR
  OPINIA_PPP
  INNE
}

enum TemplateStatus {
  ACTIVE
  ARCHIVED
}

enum KnowledgeExampleStatus {
  MODEL
  SUPPORTING
  ARCHIVED
}

enum LearningDecision {
  MODEL
  SUPPORTING
  DO_NOT_USE
}

enum ValidationStatus {
  NOT_VALIDATED
  VALID
  NEEDS_FIX
}

model Organization {
  id             String   @id @default(cuid())
  name           String
  address        String?
  documentFooter String?
  aiConfigNote   String?
  aiProvider     String?  @default("pagent_builtin")
  aiModel        String?
  aiApiUrl       String?
  aiApiKey       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users User[]
  documentTemplates DocumentTemplate[]
  knowledgeExamples KnowledgeExample[]
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  name           String?
  passwordHash   String
  role           Role          @default(USER)
  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  children     Child[]
  documents    Document[]
  uploadedFiles UploadedFile[]
  documentTemplates DocumentTemplate[]
  knowledgeExamples KnowledgeExample[]
  auditLogs    AuditLog[]
}

model Child {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  birthDate      DateTime
  school         String?
  classGroup     String?
  guardians      String?
  notes          String?
  userId         String
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents Document[]

  @@index([userId])
  @@index([lastName, firstName])
}

model Document {
  id             String         @id @default(cuid())
  title          String
  type           String
  status         DocumentStatus @default(DRAFT)
  pppType        PppDocumentType @default(OPINIA_PPP)
  specialistNotes String?
  generatedContent String?
  templateId     String?
  templateVersion String?
  validationStatus ValidationStatus @default(NOT_VALIDATED)
  validationReport Json?
  learningDecision LearningDecision?
  childId        String
  userId         String
  organizationId String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  template DocumentTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  files UploadedFile[]
  knowledgeExamples KnowledgeExample[]

  @@index([userId])
  @@index([childId])
  @@index([status])
  @@index([pppType])
  @@index([templateId])
}

model UploadedFile {
  id             String   @id @default(cuid())
  originalName   String
  storedName     String
  mimeType       String
  size           Int
  storagePath    String
  documentId     String
  userId         String
  createdAt      DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([userId])
}

model DocumentTemplate {
  id             String         @id @default(cuid())
  name           String
  type           PppDocumentType
  version        String
  status         TemplateStatus @default(ARCHIVED)
  originalName   String
  storedName     String
  mimeType       String
  size           Int
  storagePath    String
  extractedText  String
  sections       Json
  organizationId String?
  userId         String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents    Document[]

  @@unique([organizationId, type, version])
  @@index([organizationId, type, status])
  @@index([userId])
}

model KnowledgeExample {
  id             String                 @id @default(cuid())
  title          String
  type           PppDocumentType
  status         KnowledgeExampleStatus @default(SUPPORTING)
  sourceDocumentId String?
  originalName   String?
  storedName     String?
  mimeType       String?
  size           Int?
  storagePath    String?
  extractedText  String
  organizationId String?
  userId         String
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceDocument Document?   @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)

  @@index([organizationId, type, status])
  @@index([sourceDocumentId])
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  userId    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
}
