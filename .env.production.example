POSTGRES_DB="pagent"
POSTGRES_USER="pagent"
POSTGRES_PASSWORD="replace-with-a-strong-database-password"

DATABASE_URL="postgresql://pagent:replace-with-a-strong-database-password@postgres:5432/pagent?schema=public"
APP_DOMAIN="pagent.nexurio.pl"
NEXTAUTH_URL="https://pagent.nexurio.pl"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

ADMIN_EMAIL="admin@nexurio.pl"
ADMIN_PASSWORD="replace-with-a-strong-admin-password"

# Online AI agents. Gemini is recommended for speed; OpenRouter enables additional free models.
GEMINI_API_KEY=""
OPENROUTER_API_KEY=""
POLLINATIONS_API_KEY=""

# Optional, only when using a custom Dify workflow.
DIFY_API_URL=""
DIFY_API_KEY=""
